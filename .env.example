# Endpoints for the running harness. scripts/setup.sh writes the real .env after a successful
# bring-up; this file just documents the variables. Do NOT commit a real .env (it is gitignored).
export AWS_REGION=us-east-2
export DEPLOYMENT_PREFIX=rp-iceberg

# public (workstation SSH / prometheus scrape)
export SOURCE_BROKER_PUB="<src-pub-0> <src-pub-1> <src-pub-2>"
export TARGET_BROKER_PUB="<tgt-pub-0> <tgt-pub-1> <tgt-pub-2>"
export CONNECT_HOST=<connect-pub>
export PROM_HOST_TARGET=<prometheus-pub>

# private (in-VPC data plane)
export SOURCE_BROKER_0=<src-priv-0>
export SOURCE_BROKER_1=<src-priv-1>
export SOURCE_BROKER_2=<src-priv-2>
export TARGET_BROKER_0=<tgt-priv-0>
export TARGET_BROKER_1=<tgt-priv-1>
export TARGET_BROKER_2=<tgt-priv-2>
export CONNECT_PRIV=<connect-priv>
export ICEBERG_CATALOG_HOST=<connect-priv>
export ICEBERG_BUCKET=rp-iceberg-tgt-bucket
export CA=$HOME/redpanda/deployment-automation/ansible/tls/ca/ca.crt
